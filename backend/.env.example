PORT=8080
JWT_SECRET=change-this-to-a-long-random-secret-key-at-least-32-bytes
JWT_EXPIRATION_HOURS=24
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/wubebereha
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
# Render injects DATABASE_URL (postgresql://user:pass@host/db) — converted automatically at startup.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wubebereha
UPLOAD_DIR=../public/uploads
# Bootstrap admin (only when no admin exists). Required for production admin access.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=use-a-long-random-password
# Browser origin allowed to call the API with credentials (CORS).
FRONTEND_ALLOWED_ORIGIN=http://localhost:3000
